{
  "expo": {
    "name": "ConsignationApp",
    "slug": "ConsignationApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGO.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "19bcaafc-22e6-4669-a82a-e0126104d35f"
      }
    },
    "splash": {
      "image": "./assets/LOGO.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kofert.consignation",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSPhotoLibraryAddUsageDescription": "Nécessaire pour enregistrer le PDF dans vos fichiers.",
        "NSPhotoLibraryUsageDescription": "Nécessaire pour accéder à vos fichiers et enregistrer le PDF."
      }
    },
    "android": {
      "package": "com.kofert.consignation",
      "adaptiveIcon": {
        "foregroundImage": "./assets/LOGO.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/LOGO.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/LOGO.png",
          "color": "#1565C0",
          "sounds": []
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Nécessaire pour enregistrer le PDF dans vos fichiers.",
          "savePhotosPermission": "Nécessaire pour télécharger le PDF.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}